# Copy this file to `.env` and update values for your local environment.
# Do NOT commit `.env` with secrets or machine-specific values.

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
# Kestrel bind addresses (semicolon separated). Example binds both HTTPS and HTTP.
ASPNETCORE_URLS=https://localhost:[Port#];http://localhost:[Port#]

# Use mock repository (true = use in-memory mock data, false = use real DB)
USE_MOCK_DATA=true

# Database (replace with your real connection string for production)
# On Windows escape backslashes or wrap value when used in some tools.
DOTNET_CONNECTION_STRING=Server=(localdb)\\mssqllocaldb;Database=AngularProductsDb;Trusted_Connection=True;MultipleActiveResultSets=true

# Frontend
# Set to backend origin or leave empty to use same-origin relative API paths.
CLIENT_API_URL=https://localhost:[Port#]
# Alternatively set to empty to use relative '/api' paths:
# CLIENT_API_URL=

# Optional: dev certificates used by ng serve (adjust paths per OS)
SSL_CERT_PATH=%APPDATA%/ASP.NET/https/angular-products-app.client.pem
SSL_KEY_PATH=%APPDATA%/ASP.NET/https/angular-products-app.client.key

# Proxy target used by frontend dev server if needed
PROXY_TARGET=https://localhost:[Port#]